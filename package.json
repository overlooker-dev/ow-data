{
  "name": "@lunavod/ow-data",
  "version": "0.1.0",
  "description": "Shared reference data for OverwatchSpotter and OverwatchStatsMCP: hero metadata, map list, portraits, perk icons.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "default": "./dist/node.js"
    },
    "./heroes.json": "./heroes.json",
    "./maps.json": "./maps.json"
  },
  "files": [
    "dist",
    "heroes.json",
    "maps.json",
    "hero_portraits",
    "perks"
  ],
  "scripts": {
    "build": "tsc",
    "validate": "node --experimental-strip-types scripts/validate.ts",
    "prepublishOnly": "npm run build && npm run validate"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lunavod/ow-data.git"
  },
  "license": "UNLICENSED",
  "private": false,
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.6.0"
  }
}
